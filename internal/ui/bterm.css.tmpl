window { background-color: {{.Background}}; }
.bterm-tab-active { box-shadow: inset 0 0 0 1px {{.Accent}}; }
.bterm-tab-num { background-color: {{.Accent}}; color: {{.Background}}; border-radius: 5px; padding: 0 5px; font-weight: 700; }
.bterm-toast { background-color: {{.Accent}}; color: {{.Background}}; border-radius: 9px; padding: 7px 12px; }
.bterm-shortcut-key { font-family: monospace; }
